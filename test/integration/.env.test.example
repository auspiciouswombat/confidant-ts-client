# Confidant integration test configuration
# Copy to .env.test and fill in values.

# Server URL (the Confidant Connect RPC server)
CONFIDANT_SERVER_URL=http://localhost:8080

# Supabase auth (used to get JWT tokens for test users)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key-here

# Test user credentials (must exist in Supabase)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test-password-here

# Second test user (optional — for multi-user isolation tests)
# TEST_USER2_EMAIL=test2@example.com
# TEST_USER2_PASSWORD=test2-password-here
